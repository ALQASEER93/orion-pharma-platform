generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("ORION_DATABASE_URL")
}

model Tenant {
  id               String      @id @default(uuid())
  name             String
  subscriptionPlan String      @map("subscription_plan")
  createdAt        DateTime    @default(now()) @map("created_at")
  branches         Branch[]
  legalEntities    LegalEntity[]
  registers        Register[]
  users            User[]
  roles            Role[]
  auditLogs        AuditLog[]
  therapeuticClasses TherapeuticClass[]
  dosageForms        DosageForm[]
  storageConditions  StorageCondition[]
  regulatoryTypes    RegulatoryType[]
  products           Product[]
  productPacks       ProductPack[]
  lotBatches         LotBatch[]
  inventoryLedgerEntries InventoryLedgerEntry[]
  inventoryLotBalances InventoryLotBalance[]
  supplierStockReceipts SupplierStockReceipt[]
  supplierStockReceiptLines SupplierStockReceiptLine[]
  supplierStockReturns SupplierStockReturn[]
  supplierStockReturnLines SupplierStockReturnLine[]
  posCartSessions PosCartSession[]
  posCartLines PosCartLine[]
  posReturnSessions PosReturnSession[]
  posReturnLines PosReturnLine[]
  posPaymentFinalizations PosPaymentFinalization[]
  fiscalSaleDocuments FiscalSaleDocument[]
  fiscalSaleDocumentLines FiscalSaleDocumentLine[]
  fiscalReturnDocuments FiscalReturnDocument[]
  fiscalReturnDocumentLines FiscalReturnDocumentLine[]
  fiscalCreditNoteDocuments FiscalCreditNoteDocument[]
  fiscalCreditNoteDocumentLines FiscalCreditNoteDocumentLine[]
  inventoryMovements InventoryMovement[]
  inventoryBalances  InventoryBalance[]
  inventoryValuationStates InventoryValuationState[]
  inventoryValuationApplied InventoryValuationApplied[]
  suppliers          Supplier[]
  customers          Customer[]
  salesInvoices      SalesInvoice[]
  salesInvoiceLines  SalesInvoiceLine[]
  salesPayments      SalesPayment[]
  posShifts          PosShift[]
  posShiftTenderCloses PosShiftTenderClose[]
  posCloseoutHandoffs PosCloseoutHandoff[]
  posCloseoutAccountMappings PosCloseoutAccountMapping[]
  cogsPostingLinks   CogsPostingLink[]
  purchaseOrders     PurchaseOrder[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceipts      GoodsReceipt[]
  goodsReceiptLines  GoodsReceiptLine[]
  purchaseReturns    PurchaseReturn[]
  purchaseReturnLines PurchaseReturnLine[]
  procurementAdjustments ProcurementAdjustment[]
  procurementAdjustmentLines ProcurementAdjustmentLine[]
  documentSequences  DocumentSequence[]
  accounts           Account[]
  fiscalPeriods      FiscalPeriod[]
  journalEntries     JournalEntry[]
  journalLines       JournalLine[]
  postingKeys        PostingKey[]
  postingRuleSets    PostingRuleSet[]
  postingRules       PostingRule[]
  periodCloses       PeriodClose[]
  trialBalanceSnapshots TrialBalanceSnapshot[]
  statementSnapshots StatementSnapshot[]
  accountingSetting AccountingSetting?
  reconciliationRuns ReconciliationRun[]
  reconciliationResults ReconciliationResult[]
  arInvoices         ArInvoice[]
  arReceipts         ArReceipt[]
  arAllocations      ArAllocation[]
  apBills            ApBill[]
  apPayments         ApPayment[]
  apAllocations      ApAllocation[]
  prescriptions      Prescription[]
  prescriptionItems  PrescriptionItem[]
  pharmacistVerifications PharmacistVerification[]
  productWorkspaceDrafts ProductWorkspaceDraft[]
  productWorkspaceRecordStates ProductWorkspaceRecordState[]
  productWorkspaceWorklists ProductWorkspaceWorklist[]

  @@map("tenants")
}

model Supplier {
  id                   String   @id @default(uuid())
  tenantId             String   @map("tenant_id")
  code                 String
  nameAr               String   @map("name_ar")
  nameEn               String   @map("name_en")
  contactName          String?  @map("contact_name")
  email                String?
  phone                String?
  address              String?
  preferredPaymentTerm String?  @map("preferred_payment_term")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders       PurchaseOrder[]
  goodsReceipts        GoodsReceipt[]
  purchaseReturns      PurchaseReturn[]
  supplierStockReceipts SupplierStockReceipt[]
  supplierStockReturns SupplierStockReturn[]
  apBills              ApBill[]
  apPayments           ApPayment[]

  @@unique([tenantId, code])
  @@index([tenantId, nameEn])
  @@index([tenantId, nameAr])
  @@map("suppliers")
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesInvoices SalesInvoice[]
  arInvoices ArInvoice[]
  arReceipts ArReceipt[]
  prescriptions Prescription[]

  @@index([tenantId, name])
  @@index([tenantId, createdAt])
  @@map("customers")
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  legalEntityId String? @map("legal_entity_id")
  name      String
  location  String
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalEntity LegalEntity? @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  users     User[]
  registers Register[]
  inventoryLedgerEntries InventoryLedgerEntry[]
  inventoryLotBalances InventoryLotBalance[]
  supplierStockReceipts SupplierStockReceipt[]
  supplierStockReturns SupplierStockReturn[]
  posCartSessions PosCartSession[]
  posReturnSessions PosReturnSession[]
  posPaymentFinalizations PosPaymentFinalization[]
  fiscalSaleDocuments FiscalSaleDocument[]
  fiscalReturnDocuments FiscalReturnDocument[]
  fiscalCreditNoteDocuments FiscalCreditNoteDocument[]
  inventoryMovements InventoryMovement[]
  inventoryBalances  InventoryBalance[]
  inventoryValuationStates InventoryValuationState[]
  purchaseOrders     PurchaseOrder[]
  goodsReceipts      GoodsReceipt[]
  purchaseReturns    PurchaseReturn[]
  procurementAdjustments ProcurementAdjustment[]
  salesInvoices      SalesInvoice[]
  posShifts          PosShift[]
  posCloseoutHandoffs PosCloseoutHandoff[]
  prescriptions      Prescription[]
  pharmacistVerifications PharmacistVerification[]
  journalEntries     JournalEntry[]
  journalLines       JournalLine[]

  @@index([tenantId, legalEntityId])
  @@map("branches")
}

model LegalEntity {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  code               String
  nameAr             String   @map("name_ar")
  nameEn             String   @map("name_en")
  registrationNumber String?  @map("registration_number")
  taxNumber          String?  @map("tax_number")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branches           Branch[]
  registers          Register[]
  inventoryLedgerEntries InventoryLedgerEntry[]
  supplierStockReceipts SupplierStockReceipt[]
  supplierStockReturns SupplierStockReturn[]
  posCartSessions PosCartSession[]
  posReturnSessions PosReturnSession[]
  posPaymentFinalizations PosPaymentFinalization[]
  fiscalSaleDocuments FiscalSaleDocument[]
  fiscalReturnDocuments FiscalReturnDocument[]
  fiscalCreditNoteDocuments FiscalCreditNoteDocument[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive, nameEn])
  @@map("legal_entities")
}

model Register {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  legalEntityId String   @map("legal_entity_id")
  branchId      String   @map("branch_id")
  code          String
  nameAr        String   @map("name_ar")
  nameEn        String   @map("name_en")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalEntity   LegalEntity @relation(fields: [legalEntityId], references: [id], onDelete: Restrict)
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  inventoryLedgerEntries InventoryLedgerEntry[]
  posCartSessions PosCartSession[]
  posReturnSessions PosReturnSession[]
  posPaymentFinalizations PosPaymentFinalization[]
  fiscalSaleDocuments FiscalSaleDocument[]
  fiscalReturnDocuments FiscalReturnDocument[]
  fiscalCreditNoteDocuments FiscalCreditNoteDocument[]

  @@unique([tenantId, branchId, code])
  @@index([tenantId, legalEntityId, isActive])
  @@index([tenantId, branchId, isActive])
  @@map("registers")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  branchId     String?  @map("branch_id")
  roleId       String   @map("role_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  auditLogs    AuditLog[]
  inventoryLedgerEntries InventoryLedgerEntry[]
  inventoryMovements InventoryMovement[]
  supplierStockReceiptsCreated SupplierStockReceipt[] @relation("SupplierStockReceiptCreatedBy")
  supplierStockReturnsCreated SupplierStockReturn[] @relation("SupplierStockReturnCreatedBy")
  posCartSessionsCreated PosCartSession[] @relation("PosCartSessionCreatedBy")
  posReturnSessionsCreated PosReturnSession[] @relation("PosReturnSessionCreatedBy")
  posPaymentFinalizationsCreated PosPaymentFinalization[] @relation("PosPaymentFinalizationCreatedBy")
  fiscalSaleDocumentsCreated FiscalSaleDocument[] @relation("FiscalSaleDocumentCreatedBy")
  fiscalReturnDocumentsCreated FiscalReturnDocument[] @relation("FiscalReturnDocumentCreatedBy")
  fiscalCreditNotesCreated FiscalCreditNoteDocument[] @relation("FiscalCreditNoteDocumentCreatedBy")
  goodsReceiptsCreated GoodsReceipt[]
  purchaseReturnsCreated PurchaseReturn[]
  procurementAdjustmentsCreated ProcurementAdjustment[]
  salesInvoicesCreated SalesInvoice[]
  salesPaymentsCreated SalesPayment[]
  openedPosShifts  PosShift[] @relation("PosShiftOpenedBy")
  closedPosShifts  PosShift[] @relation("PosShiftClosedBy")
  generatedPosCloseoutHandoffs PosCloseoutHandoff[] @relation("PosCloseoutHandoffGeneratedBy")
  statusPosCloseoutHandoffs PosCloseoutHandoff[] @relation("PosCloseoutHandoffStatusBy")
  createdPostingRuleSets PostingRuleSet[] @relation("PostingRuleSetCreatedBy")
  periodCloses      PeriodClose[] @relation("PeriodCloseByUser")
  reconciliationRunsCreated ReconciliationRun[] @relation("ReconciliationRunCreatedBy")
  arInvoicesCreated ArInvoice[] @relation("ArInvoiceCreatedBy")
  arReceiptsCreated ArReceipt[] @relation("ArReceiptCreatedBy")
  apBillsCreated ApBill[] @relation("ApBillCreatedBy")
  apPaymentsCreated ApPayment[] @relation("ApPaymentCreatedBy")
  prescriptionsCreated Prescription[] @relation("PrescriptionCreatedBy")
  pharmacistVerifications PharmacistVerification[] @relation("PharmacistVerificationByUser")

  @@map("users")
}

model Role {
  id              String           @id @default(uuid())
  tenantId        String           @map("tenant_id")
  name            String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  userId    String?   @map("user_id")
  action    String
  entity    String
  entityId  String    @map("entity_id")
  before    Json?
  after     Json?
  createdAt DateTime  @default(now()) @map("created_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

enum TrackingMode {
  NONE
  EXPIRY_ONLY
  LOT_EXPIRY
}

enum MedicationAccessMode {
  UNSPECIFIED
  OTC
  RX
}

enum ProductPackStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum ProductPackSellability {
  UNKNOWN
  READY
  BLOCKED
}

enum LotBatchStatus {
  RECEIVED
  SELLABLE
  QUARANTINED
  EXPIRED
  DEPLETED
}

enum ProductWorkspaceFilter {
  ALL
  INCOMPLETE
  REVIEWABLE
  READY_TO_PROMOTE
  ACTIVE
  INACTIVE
}

enum ProductWorkspaceRecordKind {
  DRAFT
  PRODUCT
}

enum PrescriptionStatus {
  DRAFT
  VERIFIED
  CANCELLED
}

enum PharmacistVerificationOutcome {
  VERIFIED
  FLAGGED
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum InventoryLedgerEntryType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  RESERVE
  RELEASE
  WRITE_OFF
}

enum InventoryLedgerReferenceType {
  FOUNDATION
  MANUAL_ADJUSTMENT
  RECEIPT
  SALE
  RETURN
  TRANSFER
  SUPPLIER_RECEIPT
  SUPPLIER_RETURN
}

enum InventoryPostingSurface {
  BRANCH
  REGISTER
}

enum InventoryStockBucket {
  SELLABLE
  QUARANTINED
  EXPIRED
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  CLOSED
  CANCELLED
}

enum SupplierStockReceiptState {
  DRAFT
  POSTED
  CANCELLED
}

enum SupplierStockReturnState {
  DRAFT
  POSTED
  CANCELLED
}

enum SalesInvoiceStatus {
  DRAFT
  POSTED
  VOID
}

enum FiscalDocumentState {
  DRAFT
  FINALIZED
  QUEUED
  ACCEPTED
  REJECTED
  CANCELLED
}

enum FiscalSaleCreditState {
  NONE
  PARTIALLY_CREDITED
  FULLY_CREDITED
}

enum PosDraftState {
  ACTIVE
  ON_HOLD
}

enum PosCartSessionState {
  OPEN
  PAYMENT_PENDING
  FINALIZED
  CANCELLED
}

enum PosReturnSessionState {
  OPEN
  FINALIZED
  CANCELLED
}

enum PosPaymentFlowType {
  SALE_FINALIZATION
  RETURN_REFUND
}

enum PosPaymentFinalizationState {
  PENDING
  FINALIZED
  CANCELLED
}

enum PosShiftStatus {
  OPEN
  CLOSED
}

enum PosCloseoutHandoffStatus {
  draft_or_pending
  ready_for_posting
  posted_stub
  failed
}

enum SalesPaymentMethod {
  CASH
  CARD
  MIXED
}

enum PosCloseoutMappingKey {
  CASH_ON_HAND
  CASH_CLEARING
  CARD_CLEARING
  MIXED_CLEARING
  SALES_REVENUE
  CASH_OVER_SHORT
}

enum AccountType {
  ASSET
  LIAB
  EQUITY
  REV
  EXP
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum FiscalPeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

enum PeriodCloseStatus {
  DRAFT
  CLOSED
  REOPENED
}

enum StatementType {
  PL
  BS
}

enum ReconciliationRunStatus {
  COMPLETED
}

enum ReconciliationType {
  AR
  AP
  INV
}

enum PostingRuleSetStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum ArInvoiceStatus {
  OPEN
  PAID
  VOID
}

enum ArReceiptMethod {
  CASH
  CARD
  BANK
}

enum ArReceiptStatus {
  DRAFT
  POSTED
  VOID
}

enum ApBillStatus {
  OPEN
  PAID
  VOID
}

enum ApPaymentMethod {
  CASH
  CARD
  BANK
}

enum ApPaymentStatus {
  DRAFT
  POSTED
  VOID
}

model TherapeuticClass {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("therapeutic_classes")
}

model DosageForm {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("dosage_forms")
}

model StorageCondition {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("storage_conditions")
}

model RegulatoryType {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("regulatory_types")
}

model Product {
  id                 String                @id @default(uuid())
  tenantId           String                @map("tenant_id")
  therapeuticClassId String?               @map("therapeutic_class_id")
  dosageFormId       String?               @map("dosage_form_id")
  storageConditionId String?               @map("storage_condition_id")
  regulatoryTypeId   String?               @map("regulatory_type_id")
  nameAr             String                @map("name_ar")
  nameEn             String                @map("name_en")
  tradeNameAr        String?               @map("trade_name_ar")
  tradeNameEn        String?               @map("trade_name_en")
  genericNameAr      String?               @map("generic_name_ar")
  genericNameEn      String?               @map("generic_name_en")
  categoryAr         String?               @map("category_ar")
  categoryEn         String?               @map("category_en")
  barcode            String
  strength           String
  packSize           String                @map("pack_size")
  unitOfMeasure      String?               @map("unit_of_measure")
  taxProfileCode     String?               @map("tax_profile_code")
  medicationAccessMode MedicationAccessMode @default(UNSPECIFIED) @map("medication_access_mode")
  isActive           Boolean               @default(true) @map("is_active")
  trackingMode       TrackingMode          @default(NONE) @map("tracking_mode")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  therapeuticClass   TherapeuticClass?     @relation(fields: [therapeuticClassId], references: [id], onDelete: SetNull)
  dosageForm         DosageForm?           @relation(fields: [dosageFormId], references: [id], onDelete: SetNull)
  storageCondition   StorageCondition?     @relation(fields: [storageConditionId], references: [id], onDelete: SetNull)
  regulatoryType     RegulatoryType?       @relation(fields: [regulatoryTypeId], references: [id], onDelete: SetNull)
  inventoryMovements InventoryMovement[]
  inventoryBalances  InventoryBalance[]
  inventoryValuationStates InventoryValuationState[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceiptLines  GoodsReceiptLine[]
  purchaseReturnLines PurchaseReturnLine[]
  procurementAdjustmentLines ProcurementAdjustmentLine[]
  salesInvoiceLines  SalesInvoiceLine[]
  prescriptionItems  PrescriptionItem[]
  productPacks       ProductPack[]
  workspaceCatalogDrafts ProductWorkspaceDraft[] @relation("WorkspaceCatalogProduct")
  workspaceBasedDrafts ProductWorkspaceDraft[] @relation("WorkspaceBasedProduct")

  @@unique([tenantId, barcode])
  @@index([tenantId, nameEn])
  @@index([tenantId, nameAr])
  @@index([tenantId, tradeNameEn])
  @@index([tenantId, genericNameEn])
  @@index([tenantId, isActive, nameEn])
  @@map("products")
}

model ProductPack {
  id           String                 @id @default(uuid())
  tenantId     String                 @map("tenant_id")
  productId    String                 @map("product_id")
  code         String
  barcode      String?
  unitsPerPack Int                    @default(1) @map("units_per_pack")
  status       ProductPackStatus      @default(DRAFT)
  sellability  ProductPackSellability @default(UNKNOWN)
  isDefault    Boolean                @default(false) @map("is_default")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product      Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  lotBatches   LotBatch[]
  inventoryLedgerEntries InventoryLedgerEntry[]
  inventoryLotBalances InventoryLotBalance[]
  supplierStockReceiptLines SupplierStockReceiptLine[]
  supplierStockReturnLines SupplierStockReturnLine[]
  posCartLines PosCartLine[]
  posReturnLines PosReturnLine[]
  fiscalSaleDocumentLines FiscalSaleDocumentLine[]
  fiscalReturnDocumentLines FiscalReturnDocumentLine[]
  fiscalCreditNoteDocumentLines FiscalCreditNoteDocumentLine[]

  @@unique([tenantId, code])
  @@index([tenantId, productId, status])
  @@index([tenantId, productId, sellability])
  @@map("product_packs")
}

model LotBatch {
  id               String         @id @default(uuid())
  tenantId         String         @map("tenant_id")
  productPackId    String         @map("product_pack_id")
  batchNo          String         @map("batch_no")
  expiryDate       DateTime?      @map("expiry_date")
  receivedOn       DateTime       @default(now()) @map("received_on")
  status           LotBatchStatus @default(RECEIVED)
  isSellable       Boolean        @default(true) @map("is_sellable")
  quarantinedAt    DateTime?      @map("quarantined_at")
  quarantineReason String?        @map("quarantine_reason")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productPack      ProductPack    @relation(fields: [productPackId], references: [id], onDelete: Restrict)
  inventoryLedgerEntries InventoryLedgerEntry[]
  inventoryLotBalances InventoryLotBalance[]
  supplierStockReceiptLines SupplierStockReceiptLine[]
  supplierStockReturnLines SupplierStockReturnLine[]
  posCartLines PosCartLine[]
  posReturnLines PosReturnLine[]
  fiscalSaleDocumentLines FiscalSaleDocumentLine[]
  fiscalReturnDocumentLines FiscalReturnDocumentLine[]
  fiscalCreditNoteDocumentLines FiscalCreditNoteDocumentLine[]

  @@unique([tenantId, productPackId, batchNo])
  @@index([tenantId, status, expiryDate])
  @@index([tenantId, isSellable, expiryDate])
  @@map("lot_batches")
}

model ProductWorkspaceDraft {
  id              String       @id @default(uuid())
  tenantId        String       @unique @map("tenant_id")
  nameAr          String       @default("") @map("name_ar")
  nameEn          String       @default("") @map("name_en")
  barcode         String       @default("")
  strength        String       @default("")
  packSize        String       @default("") @map("pack_size")
  trackingMode    TrackingMode @default(NONE) @map("tracking_mode")
  catalogProductId String?     @map("catalog_product_id")
  basedOnProductId String?     @map("based_on_product_id")
  lastPromotedAt  DateTime?    @map("last_promoted_at")
  lastActivatedAt DateTime?    @map("last_activated_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
