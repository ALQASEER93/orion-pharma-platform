  unitCost               Float?                 @map("unit_cost")
  lineTotal              Float?                 @map("line_total")
  inventoryLedgerEntryId String?                @unique @map("inventory_ledger_entry_id")
  notes                  String?
  createdAt              DateTime               @default(now()) @map("created_at")
  receipt                SupplierStockReceipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productPack            ProductPack            @relation(fields: [productPackId], references: [id], onDelete: Restrict)
  lotBatch               LotBatch               @relation(fields: [lotBatchId], references: [id], onDelete: Restrict)
  inventoryLedgerEntry   InventoryLedgerEntry?  @relation(fields: [inventoryLedgerEntryId], references: [id], onDelete: SetNull)
  supplierReturnLines    SupplierStockReturnLine[]

  @@unique([receiptId, lineNo])
  @@index([tenantId, receiptId])
  @@index([tenantId, productPackId, lotBatchId])
  @@map("supplier_stock_receipt_lines")
}

model SupplierStockReturn {
  id              String                  @id @default(uuid())
  tenantId        String                  @map("tenant_id")
  legalEntityId   String?                 @map("legal_entity_id")
  branchId        String                  @map("branch_id")
  supplierId      String                  @map("supplier_id")
  sourceReceiptId String?                 @map("source_receipt_id")
  returnNumber    String                  @map("return_number")
  state           SupplierStockReturnState @default(DRAFT)
  reasonCode      String?                 @map("reason_code")
  notes           String?
  returnedAt      DateTime                @default(now()) @map("returned_at")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")
  createdBy       String?                 @map("created_by")
  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalEntity     LegalEntity?            @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  branch          Branch                  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  supplier        Supplier                @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  sourceReceipt   SupplierStockReceipt?   @relation(fields: [sourceReceiptId], references: [id], onDelete: SetNull)
  creator         User?                   @relation("SupplierStockReturnCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  lines           SupplierStockReturnLine[]

  @@unique([tenantId, returnNumber])
  @@index([tenantId, sourceReceiptId])
  @@index([tenantId, supplierId, state, returnedAt])
  @@map("supplier_stock_returns")
}

model SupplierStockReturnLine {
  id                     String                 @id @default(uuid())
  returnId               String                 @map("return_id")
  tenantId               String                 @map("tenant_id")
  sourceReceiptLineId    String?                @map("source_receipt_line_id")
  lineNo                 Int                    @default(1) @map("line_no")
  productPackId          String                 @map("product_pack_id")
  lotBatchId             String                 @map("lot_batch_id")
  quantityReturned       Int                    @map("quantity_returned")
  reasonCode             String?                @map("reason_code")
  inventoryLedgerEntryId String?                @unique @map("inventory_ledger_entry_id")
  notes                  String?
  createdAt              DateTime               @default(now()) @map("created_at")
  supplierReturn         SupplierStockReturn    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceReceiptLine      SupplierStockReceiptLine? @relation(fields: [sourceReceiptLineId], references: [id], onDelete: SetNull)
  productPack            ProductPack            @relation(fields: [productPackId], references: [id], onDelete: Restrict)
  lotBatch               LotBatch               @relation(fields: [lotBatchId], references: [id], onDelete: Restrict)
  inventoryLedgerEntry   InventoryLedgerEntry?  @relation(fields: [inventoryLedgerEntryId], references: [id], onDelete: SetNull)

  @@unique([returnId, lineNo])
  @@index([tenantId, returnId])
  @@index([tenantId, sourceReceiptLineId])
  @@index([tenantId, productPackId, lotBatchId])
  @@map("supplier_stock_return_lines")
}

model ProcurementAdjustment {
  id                 String                      @id @default(uuid())
  tenantId           String                      @map("tenant_id")
  branchId           String                      @map("branch_id")
  adjustmentNumber   String                      @map("adjustment_number")
  reasonCode         String                      @map("reason_code")
  sourceRefType      String?                     @map("source_ref_type")
  sourceRefId        String?                     @map("source_ref_id")
  notes              String?
  adjustedAt         DateTime                    @default(now()) @map("adjusted_at")
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")
  createdBy          String?                     @map("created_by")
  tenant             Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch             Branch                      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  creator            User?                       @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  lines              ProcurementAdjustmentLine[]

  @@unique([tenantId, adjustmentNumber])
  @@index([tenantId, adjustedAt])
  @@map("procurement_adjustments")
}

model ProcurementAdjustmentLine {
  id                      String                 @id @default(uuid())
  procurementAdjustmentId String                 @map("procurement_adjustment_id")
  tenantId                String                 @map("tenant_id")
  productId               String                 @map("product_id")
  inventoryMovementId     String?                @unique @map("inventory_movement_id")
  quantityDelta           Int                    @map("quantity_delta")
  reasonCode              String?                @map("reason_code")
  batchNo                 String?                @map("batch_no")
  expiryDate              DateTime?              @map("expiry_date")
  unitCost                Float?                 @map("unit_cost")
  notes                   String?
  createdAt               DateTime               @default(now()) @map("created_at")
  procurementAdjustment   ProcurementAdjustment  @relation(fields: [procurementAdjustmentId], references: [id], onDelete: Cascade)
  tenant                  Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product                 Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  inventoryMovement       InventoryMovement?     @relation(fields: [inventoryMovementId], references: [id], onDelete: SetNull)

  @@index([tenantId, procurementAdjustmentId])
  @@index([tenantId, productId])
  @@map("procurement_adjustment_lines")
}
