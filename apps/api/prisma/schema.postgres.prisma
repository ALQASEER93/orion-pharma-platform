  creditNoteDocumentId String                   @map("credit_note_document_id")
  tenantId           String                     @map("tenant_id")
  sourceSaleLineId   String?                    @map("source_sale_line_id")
  sourceReturnLineId String?                    @map("source_return_line_id")
  lineNo             Int                        @default(1) @map("line_no")
  productPackId      String?                    @map("product_pack_id")
  lotBatchId         String?                    @map("lot_batch_id")
  quantity           Float
  unitPrice          Float                      @map("unit_price")
  discount           Float                      @default(0)
  taxRate            Float?                     @map("tax_rate")
  lineTotal          Float                      @default(0) @map("line_total")
  reasonCode         String?                    @map("reason_code")
  createdAt          DateTime                   @default(now()) @map("created_at")
  creditNoteDocument FiscalCreditNoteDocument   @relation(fields: [creditNoteDocumentId], references: [id], onDelete: Cascade)
  tenant             Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceSaleLine     FiscalSaleDocumentLine?    @relation("FiscalCreditLineSourceSaleLine", fields: [sourceSaleLineId], references: [id], onDelete: SetNull)
  sourceReturnLine   FiscalReturnDocumentLine?  @relation("FiscalCreditLineSourceReturnLine", fields: [sourceReturnLineId], references: [id], onDelete: SetNull)
  productPack        ProductPack?               @relation(fields: [productPackId], references: [id], onDelete: SetNull)
  lotBatch           LotBatch?                  @relation(fields: [lotBatchId], references: [id], onDelete: SetNull)

  @@unique([creditNoteDocumentId, lineNo])
  @@index([tenantId, creditNoteDocumentId])
  @@index([tenantId, sourceSaleLineId])
  @@index([tenantId, sourceReturnLineId])
  @@index([tenantId, productPackId, lotBatchId])
  @@map("fiscal_credit_note_document_lines")
}

model PosCartSession {
  id                   String               @id @default(uuid())
  tenantId             String               @map("tenant_id")
  legalEntityId        String?              @map("legal_entity_id")
  branchId             String               @map("branch_id")
  registerId           String               @map("register_id")
  sessionNumber        String               @map("session_number")
  state                PosCartSessionState  @default(OPEN)
  currency             String               @default("JOD")
  subtotal             Float                @default(0)
  discountTotal        Float                @default(0) @map("discount_total")
  taxTotal             Float                @default(0) @map("tax_total")
  grandTotal           Float                @default(0) @map("grand_total")
  openedAt             DateTime             @default(now()) @map("opened_at")
  finalizedAt          DateTime?            @map("finalized_at")
  cancelledAt          DateTime?            @map("cancelled_at")
  cancellationReason   String?              @map("cancellation_reason")
  notes                String?
  fiscalSaleDocumentId String?              @unique @map("fiscal_sale_document_id")
  createdBy            String?              @map("created_by")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalEntity          LegalEntity?         @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  branch               Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  register             Register             @relation(fields: [registerId], references: [id], onDelete: Restrict)
  fiscalSaleDocument   FiscalSaleDocument?  @relation(fields: [fiscalSaleDocumentId], references: [id], onDelete: SetNull)
  creator              User?                @relation("PosCartSessionCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  lines                PosCartLine[]
  paymentFinalizations PosPaymentFinalization[] @relation("PosCartSessionPaymentFinalizations")

  @@unique([tenantId, sessionNumber])
  @@index([tenantId, branchId, registerId, state, openedAt])
  @@index([tenantId, legalEntityId, state, openedAt])
  @@map("pos_cart_sessions")
}

model PosCartLine {
  id                     String                  @id @default(uuid())
  cartSessionId          String                  @map("cart_session_id")
  tenantId               String                  @map("tenant_id")
  lineNo                 Int                     @default(1) @map("line_no")
  productPackId          String                  @map("product_pack_id")
  lotBatchId             String                  @map("lot_batch_id")
  quantity               Int
  unitPrice              Float                   @map("unit_price")
  discount               Float                   @default(0)
  taxRate                Float?                  @map("tax_rate")
  lineTotal              Float                   @default(0) @map("line_total")
  fiscalSaleLineId       String?                 @unique @map("fiscal_sale_line_id")
  inventoryLedgerEntryId String?                 @unique @map("inventory_ledger_entry_id")
  notes                  String?
  createdAt              DateTime                @default(now()) @map("created_at")
  cartSession            PosCartSession          @relation(fields: [cartSessionId], references: [id], onDelete: Cascade)
  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productPack            ProductPack             @relation(fields: [productPackId], references: [id], onDelete: Restrict)
  lotBatch               LotBatch                @relation(fields: [lotBatchId], references: [id], onDelete: Restrict)
  fiscalSaleLine         FiscalSaleDocumentLine? @relation(fields: [fiscalSaleLineId], references: [id], onDelete: SetNull)
  inventoryLedgerEntry   InventoryLedgerEntry?   @relation(fields: [inventoryLedgerEntryId], references: [id], onDelete: SetNull)

  @@unique([cartSessionId, lineNo])
  @@index([tenantId, cartSessionId])
  @@index([tenantId, productPackId, lotBatchId])
  @@map("pos_cart_lines")
}

