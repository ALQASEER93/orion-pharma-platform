model PosPaymentFinalization {
  id                     String                      @id @default(uuid())
  tenantId               String                      @map("tenant_id")
  legalEntityId          String?                     @map("legal_entity_id")
  branchId               String                      @map("branch_id")
  registerId             String                      @map("register_id")
  cartSessionId          String?                     @map("cart_session_id")
  returnSessionId        String?                     @map("return_session_id")
  fiscalSaleDocumentId   String?                     @map("fiscal_sale_document_id")
  fiscalReturnDocumentId String?                     @map("fiscal_return_document_id")
  flowType               PosPaymentFlowType          @map("flow_type")
  state                  PosPaymentFinalizationState @default(PENDING)
  paymentMethod          SalesPaymentMethod          @map("payment_method")
  amountApplied          Float                       @map("amount_applied")
  amountTendered         Float?                      @map("amount_tendered")
  changeAmount           Float                       @default(0) @map("change_amount")
  referenceCode          String?                     @map("reference_code")
  notes                  String?
  finalizedAt            DateTime?                   @map("finalized_at")
  cancelledAt            DateTime?                   @map("cancelled_at")
  cancellationReason     String?                     @map("cancellation_reason")
  createdBy              String?                     @map("created_by")
  createdAt              DateTime                    @default(now()) @map("created_at")
  updatedAt              DateTime                    @updatedAt @map("updated_at")
  tenant                 Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalEntity            LegalEntity?                @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  branch                 Branch                      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  register               Register                    @relation(fields: [registerId], references: [id], onDelete: Restrict)
  cartSession            PosCartSession?             @relation("PosCartSessionPaymentFinalizations", fields: [cartSessionId], references: [id], onDelete: SetNull)
  returnSession          PosReturnSession?           @relation("PosReturnSessionPaymentFinalizations", fields: [returnSessionId], references: [id], onDelete: SetNull)
  fiscalSaleDocument     FiscalSaleDocument?         @relation("PosPaymentFinalizationSale", fields: [fiscalSaleDocumentId], references: [id], onDelete: SetNull)
  fiscalReturnDocument   FiscalReturnDocument?       @relation("PosPaymentFinalizationReturn", fields: [fiscalReturnDocumentId], references: [id], onDelete: SetNull)
  creator                User?                       @relation("PosPaymentFinalizationCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, registerId, flowType, createdAt])
  @@index([tenantId, cartSessionId])
  @@index([tenantId, returnSessionId])
  @@index([tenantId, fiscalSaleDocumentId])
  @@index([tenantId, fiscalReturnDocumentId])
  @@map("pos_payment_finalizations")
}

model SalesInvoice {
  id              String             @id @default(uuid())
  tenantId        String             @map("tenant_id")
  invoiceNo       String             @map("invoice_no")
  idempotencyKey  String?            @map("idempotency_key")
  payloadHash     String?            @map("payload_hash")
  status          SalesInvoiceStatus @default(DRAFT)
  posDraftState   PosDraftState      @default(ACTIVE) @map("pos_draft_state")
  heldAt          DateTime?          @map("held_at")
  issuedAt        DateTime           @default(now()) @map("issued_at")
  branchId        String?            @map("branch_id")
  customerId      String?            @map("customer_id")
  prescriptionId  String?            @map("prescription_id")
  currency        String             @default("JOD")
  subtotal        Float              @default(0)
  discountTotal   Float              @default(0) @map("discount_total")
  taxTotal        Float              @default(0) @map("tax_total")
  grandTotal      Float              @default(0) @map("grand_total")
  createdByUserId String?            @map("created_by_user_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer        Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  prescription    Prescription?      @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  createdBy       User?              @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines           SalesInvoiceLine[]
  payments        SalesPayment[]
  arInvoice       ArInvoice?
  cogsPostingLink CogsPostingLink?

  @@unique([tenantId, invoiceNo])
  @@index([tenantId, issuedAt])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, customerId])
  @@index([tenantId, branchId])
  @@index([tenantId, prescriptionId])
  @@unique([tenantId, idempotencyKey])
  @@map("sales_invoices")
}

model SalesInvoiceLine {
  id             String       @id @default(uuid())
  invoiceId      String       @map("invoice_id")
  tenantId       String       @map("tenant_id")
  productId      String?      @map("product_id")
  prescriptionItemId String?  @map("prescription_item_id")
  itemName       String       @map("item_name")
  qty            Float
  unitPrice      Float        @map("unit_price")
  discount       Float        @default(0)
  taxRate        Float?       @map("tax_rate")
  lineTotal      Float        @default(0) @map("line_total")
  unitCostSnapshot Float?     @map("unit_cost_snapshot")
  costMethodSnapshot String?  @map("cost_method_snapshot")
  createdAt      DateTime     @default(now()) @map("created_at")
  salesInvoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product        Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  prescriptionItem PrescriptionItem? @relation(fields: [prescriptionItemId], references: [id], onDelete: SetNull)
  inventoryMovements InventoryMovement[]

  @@index([tenantId, invoiceId])
  @@index([tenantId, productId])
  @@index([tenantId, prescriptionItemId])
  @@map("sales_invoice_lines")
}

model SalesPayment {
  id          String             @id @default(uuid())
  invoiceId   String             @map("invoice_id")
  tenantId    String             @map("tenant_id")
  posShiftId  String?            @map("pos_shift_id")
  method      SalesPaymentMethod
  amount      Float
  paidAt      DateTime           @default(now()) @map("paid_at")
  createdByUserId String?        @map("created_by_user_id")
  createdAt   DateTime           @default(now()) @map("created_at")
  salesInvoice SalesInvoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posShift    PosShift?          @relation(fields: [posShiftId], references: [id], onDelete: SetNull)
  createdBy   User?              @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, invoiceId, paidAt])
  @@index([tenantId, posShiftId, paidAt])
  @@map("sales_payments")
}

model PosShift {
  id            String         @id @default(uuid())
  tenantId      String         @map("tenant_id")
  branchId      String         @map("branch_id")
  status        PosShiftStatus @default(OPEN)
  openedAt      DateTime       @default(now()) @map("opened_at")
  openedByUserId String        @map("opened_by_user_id")
  openingFloat  Float          @default(0) @map("opening_float")
  closedAt      DateTime?      @map("closed_at")
  closedByUserId String?       @map("closed_by_user_id")
  expectedTotal Float          @default(0) @map("expected_total")
  declaredTotal Float          @default(0) @map("declared_total")
  varianceTotal Float          @default(0) @map("variance_total")
  closeNote     String?        @map("close_note")
  varianceNote  String?        @map("variance_note")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  openedBy      User           @relation("PosShiftOpenedBy", fields: [openedByUserId], references: [id], onDelete: Restrict)
  closedBy      User?          @relation("PosShiftClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
  payments      SalesPayment[]
  tenderClosures PosShiftTenderClose[]
  closeoutHandoffs PosCloseoutHandoff[]

  @@index([tenantId, branchId, status, openedAt])
  @@index([tenantId, openedByUserId, status])
  @@index([tenantId, closedAt])
  @@map("pos_shifts")
}

model PosShiftTenderClose {
  id             String             @id @default(uuid())
  shiftId        String             @map("shift_id")
  tenantId       String             @map("tenant_id")
  method         SalesPaymentMethod
  expectedAmount Float              @default(0) @map("expected_amount")
  declaredAmount Float              @default(0) @map("declared_amount")
  varianceAmount Float              @default(0) @map("variance_amount")
  note           String?
  createdAt      DateTime           @default(now()) @map("created_at")
  shift          PosShift           @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([shiftId, method])
  @@index([tenantId, shiftId])
  @@map("pos_shift_tender_closes")
}

model PosCloseoutHandoff {
  id                    String                   @id @default(uuid())
  tenantId              String                   @map("tenant_id")
  branchId              String                   @map("branch_id")
  posShiftId            String?                  @map("pos_shift_id")
  dayCloseId            String?                  @map("day_close_id")
  posSessionId          String?                  @map("pos_session_id")
  businessDate          DateTime                 @map("business_date")
  closedAt              DateTime                 @map("closed_at")
  currency              String
  openingFloat          Float                    @default(0) @map("opening_float")
  tenderTotals          Json                     @map("tender_totals")
  expectedTotals        Json                     @map("expected_totals")
  declaredTotals        Json                     @map("declared_totals")
  overShortTotals       Json                     @map("over_short_totals")
  netSalesBasis         Json                     @map("net_sales_basis")
  sourceStatus          String                   @map("source_status")
  lifecycleStatus       PosCloseoutHandoffStatus @default(draft_or_pending) @map("lifecycle_status")
  sourcePayloadHash     String                   @map("source_payload_hash")
  sourcePayload         Json                     @map("source_payload")
  generatedByUserId     String?                  @map("generated_by_user_id")
  generatedAt           DateTime                 @default(now()) @map("generated_at")
  lastStatusActorUserId String?                  @map("last_status_actor_user_id")
  lastStatusAt          DateTime?                @map("last_status_at")
  lastStatusReason      String?                  @map("last_status_reason")
  supersedesHandoffId   String?                  @map("supersedes_handoff_id")
  supersededAt          DateTime?                @map("superseded_at")
  deferredFields        Json?                    @map("deferred_fields")
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")
  tenant                Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch                Branch                   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  posShift              PosShift?                @relation(fields: [posShiftId], references: [id], onDelete: SetNull)
  generatedBy           User?                    @relation("PosCloseoutHandoffGeneratedBy", fields: [generatedByUserId], references: [id], onDelete: SetNull)
  lastStatusActor       User?                    @relation("PosCloseoutHandoffStatusBy", fields: [lastStatusActorUserId], references: [id], onDelete: SetNull)
  supersedesHandoff     PosCloseoutHandoff?      @relation("PosCloseoutHandoffSupersedes", fields: [supersedesHandoffId], references: [id], onDelete: SetNull)
  regeneratedHandoffs   PosCloseoutHandoff[]     @relation("PosCloseoutHandoffSupersedes")

  @@unique([tenantId, posShiftId, sourcePayloadHash])
  @@index([tenantId, branchId, businessDate, generatedAt])
  @@index([tenantId, posShiftId, generatedAt])
  @@index([tenantId, lifecycleStatus, generatedAt])
  @@map("pos_closeout_handoffs")
}

model PosCloseoutAccountMapping {
  id         String               @id @default(uuid())
  tenantId   String               @map("tenant_id")
  mappingKey PosCloseoutMappingKey @map("mapping_key")
  accountRef String               @map("account_ref")
