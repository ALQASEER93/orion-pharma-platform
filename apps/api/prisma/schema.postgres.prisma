generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("ORION_DATABASE_URL")
}

model Tenant {
  id               String      @id @default(uuid())
  name             String
  subscriptionPlan String      @map("subscription_plan")
  createdAt        DateTime    @default(now()) @map("created_at")
  branches         Branch[]
  users            User[]
  roles            Role[]
  auditLogs        AuditLog[]
  therapeuticClasses TherapeuticClass[]
  dosageForms        DosageForm[]
  storageConditions  StorageCondition[]
  regulatoryTypes    RegulatoryType[]
  products           Product[]
  inventoryMovements InventoryMovement[]
  inventoryBalances  InventoryBalance[]
  inventoryValuationStates InventoryValuationState[]
  inventoryValuationApplied InventoryValuationApplied[]
  suppliers          Supplier[]
  customers          Customer[]
  salesInvoices      SalesInvoice[]
  salesInvoiceLines  SalesInvoiceLine[]
  salesPayments      SalesPayment[]
  cogsPostingLinks   CogsPostingLink[]
  purchaseOrders     PurchaseOrder[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceipts      GoodsReceipt[]
  goodsReceiptLines  GoodsReceiptLine[]
  purchaseReturns    PurchaseReturn[]
  purchaseReturnLines PurchaseReturnLine[]
  procurementAdjustments ProcurementAdjustment[]
  procurementAdjustmentLines ProcurementAdjustmentLine[]
  documentSequences  DocumentSequence[]
  accounts           Account[]
  fiscalPeriods      FiscalPeriod[]
  journalEntries     JournalEntry[]
  journalLines       JournalLine[]
  postingKeys        PostingKey[]
  postingRuleSets    PostingRuleSet[]
  postingRules       PostingRule[]
  periodCloses       PeriodClose[]
  trialBalanceSnapshots TrialBalanceSnapshot[]
  statementSnapshots StatementSnapshot[]
  accountingSetting AccountingSetting?
  reconciliationRuns ReconciliationRun[]
  reconciliationResults ReconciliationResult[]
  arInvoices         ArInvoice[]
  arReceipts         ArReceipt[]
  arAllocations      ArAllocation[]
  apBills            ApBill[]
  apPayments         ApPayment[]
  apAllocations      ApAllocation[]

  @@map("tenants")
}

model Supplier {
  id                   String   @id @default(uuid())
  tenantId             String   @map("tenant_id")
  code                 String
  nameAr               String   @map("name_ar")
  nameEn               String   @map("name_en")
  contactName          String?  @map("contact_name")
  email                String?
  phone                String?
  address              String?
  preferredPaymentTerm String?  @map("preferred_payment_term")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders       PurchaseOrder[]
  goodsReceipts        GoodsReceipt[]
  purchaseReturns      PurchaseReturn[]
  apBills              ApBill[]
  apPayments           ApPayment[]

  @@unique([tenantId, code])
  @@index([tenantId, nameEn])
  @@index([tenantId, nameAr])
  @@map("suppliers")
}

model Customer {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesInvoices SalesInvoice[]
  arInvoices ArInvoice[]
  arReceipts ArReceipt[]

  @@index([tenantId, name])
  @@index([tenantId, createdAt])
  @@map("customers")
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  location  String
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users     User[]
  inventoryMovements InventoryMovement[]
  inventoryBalances  InventoryBalance[]
  inventoryValuationStates InventoryValuationState[]
  purchaseOrders     PurchaseOrder[]
  goodsReceipts      GoodsReceipt[]
  purchaseReturns    PurchaseReturn[]
  procurementAdjustments ProcurementAdjustment[]
  salesInvoices      SalesInvoice[]
  journalEntries     JournalEntry[]
  journalLines       JournalLine[]

  @@map("branches")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  branchId     String?  @map("branch_id")
  roleId       String   @map("role_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  auditLogs    AuditLog[]
  inventoryMovements InventoryMovement[]
  goodsReceiptsCreated GoodsReceipt[]
  purchaseReturnsCreated PurchaseReturn[]
  procurementAdjustmentsCreated ProcurementAdjustment[]
  salesInvoicesCreated SalesInvoice[]
  salesPaymentsCreated SalesPayment[]
  createdPostingRuleSets PostingRuleSet[] @relation("PostingRuleSetCreatedBy")
  periodCloses      PeriodClose[] @relation("PeriodCloseByUser")
  reconciliationRunsCreated ReconciliationRun[] @relation("ReconciliationRunCreatedBy")
  arInvoicesCreated ArInvoice[] @relation("ArInvoiceCreatedBy")
  arReceiptsCreated ArReceipt[] @relation("ArReceiptCreatedBy")
  apBillsCreated ApBill[] @relation("ApBillCreatedBy")
  apPaymentsCreated ApPayment[] @relation("ApPaymentCreatedBy")

  @@map("users")
}

model Role {
  id              String           @id @default(uuid())
  tenantId        String           @map("tenant_id")
  name            String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  userId    String?   @map("user_id")
  action    String
  entity    String
  entityId  String    @map("entity_id")
  before    Json?
  after     Json?
  createdAt DateTime  @default(now()) @map("created_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

enum TrackingMode {
  NONE
  EXPIRY_ONLY
  LOT_EXPIRY
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  CLOSED
  CANCELLED
}

enum SalesInvoiceStatus {
  DRAFT
  POSTED
  VOID
}

enum SalesPaymentMethod {
  CASH
  CARD
  MIXED
}

enum AccountType {
  ASSET
  LIAB
  EQUITY
  REV
  EXP
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum FiscalPeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

enum PeriodCloseStatus {
  DRAFT
  CLOSED
  REOPENED
}

enum StatementType {
  PL
  BS
}

enum ReconciliationRunStatus {
  COMPLETED
}

enum ReconciliationType {
  AR
  AP
  INV
}

enum PostingRuleSetStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum ArInvoiceStatus {
  OPEN
  PAID
  VOID
}

enum ArReceiptMethod {
  CASH
  CARD
  BANK
}

enum ArReceiptStatus {
  DRAFT
  POSTED
  VOID
}

enum ApBillStatus {
  OPEN
  PAID
  VOID
}

enum ApPaymentMethod {
  CASH
  CARD
  BANK
}

enum ApPaymentStatus {
  DRAFT
  POSTED
  VOID
}

model TherapeuticClass {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("therapeutic_classes")
}

model DosageForm {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("dosage_forms")
}

model StorageCondition {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("storage_conditions")
}

model RegulatoryType {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("regulatory_types")
}

model Product {
  id                 String                @id @default(uuid())
  tenantId           String                @map("tenant_id")
  therapeuticClassId String?               @map("therapeutic_class_id")
  dosageFormId       String?               @map("dosage_form_id")
  storageConditionId String?               @map("storage_condition_id")
  regulatoryTypeId   String?               @map("regulatory_type_id")
  nameAr             String                @map("name_ar")
  nameEn             String                @map("name_en")
  barcode            String
  strength           String
  packSize           String                @map("pack_size")
  trackingMode       TrackingMode          @default(NONE) @map("tracking_mode")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  therapeuticClass   TherapeuticClass?     @relation(fields: [therapeuticClassId], references: [id], onDelete: SetNull)
  dosageForm         DosageForm?           @relation(fields: [dosageFormId], references: [id], onDelete: SetNull)
  storageCondition   StorageCondition?     @relation(fields: [storageConditionId], references: [id], onDelete: SetNull)
  regulatoryType     RegulatoryType?       @relation(fields: [regulatoryTypeId], references: [id], onDelete: SetNull)
  inventoryMovements InventoryMovement[]
  inventoryBalances  InventoryBalance[]
  inventoryValuationStates InventoryValuationState[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceiptLines  GoodsReceiptLine[]
  purchaseReturnLines PurchaseReturnLine[]
  procurementAdjustmentLines ProcurementAdjustmentLine[]
  salesInvoiceLines  SalesInvoiceLine[]

  @@unique([tenantId, barcode])
  @@index([tenantId, nameEn])
  @@index([tenantId, nameAr])
  @@map("products")
}

model InventoryMovement {
  id           String                @id @default(uuid())
  tenantId     String                @map("tenant_id")
  branchId     String                @map("branch_id")
  productId    String                @map("product_id")
  batchNo      String?               @map("batch_no")
  expiryDate   DateTime?             @map("expiry_date")
  businessDate DateTime              @default(now()) @map("business_date")
  movementType InventoryMovementType @map("movement_type")
  quantity     Int
  unitCost     Float?               @map("unit_cost")
  costTotal    Float?               @map("cost_total")
  reason       String?
  createdAt    DateTime              @default(now()) @map("created_at")
  createdBy    String?               @map("created_by")
  salesInvoiceLineId String?         @map("sales_invoice_line_id")
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch                @relation(fields: [branchId], references: [id], onDelete: Restrict)
  product      Product               @relation(fields: [productId], references: [id], onDelete: Restrict)
  user         User?                 @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  salesInvoiceLine SalesInvoiceLine? @relation(fields: [salesInvoiceLineId], references: [id], onDelete: SetNull)
  goodsReceiptLine GoodsReceiptLine?
  purchaseReturnLine PurchaseReturnLine?
  procurementAdjustmentLine ProcurementAdjustmentLine?
  valuationApplied InventoryValuationApplied?

  @@index([tenantId, branchId, productId, batchNo])
  @@index([tenantId, businessDate])
  @@index([tenantId, salesInvoiceLineId])
  @@unique([salesInvoiceLineId, batchNo])
  @@map("inventory_movements")
}

model InventoryBalance {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  branchId  String   @map("branch_id")
  productId String   @map("product_id")
  batchNo   String   @default("") @map("batch_no")
  quantity  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([tenantId, branchId, productId, batchNo])
  @@index([tenantId, branchId, productId])
  @@map("inventory_balances")
}

model InventoryValuationState {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  branchId       String   @map("branch_id")
  productId      String   @map("product_id")
  qtyOnHand      Float    @default(0) @map("qty_on_hand")
  avgUnitCost    Float    @default(0) @map("avg_unit_cost")
  inventoryValue Float    @default(0) @map("inventory_value")
  updatedAt      DateTime @updatedAt @map("updated_at")
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([tenantId, branchId, productId])
  @@index([tenantId, branchId])
  @@map("inventory_valuation_states")
}

model InventoryValuationApplied {
  id                  String            @id @default(uuid())
  tenantId            String            @map("tenant_id")
  inventoryMovementId String            @map("inventory_movement_id")
  appliedAt           DateTime          @default(now()) @map("applied_at")
  tenant              Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryMovement   InventoryMovement @relation(fields: [inventoryMovementId], references: [id], onDelete: Cascade)

  @@unique([tenantId, inventoryMovementId])
  @@unique([inventoryMovementId])
  @@index([tenantId, appliedAt])
  @@map("inventory_valuation_applied")
}

model DocumentSequence {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  key        String
  nextNumber Int      @default(1) @map("next_number")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@map("document_sequences")
}

model SalesInvoice {
  id              String             @id @default(uuid())
  tenantId        String             @map("tenant_id")
  invoiceNo       String             @map("invoice_no")
  idempotencyKey  String?            @map("idempotency_key")
  payloadHash     String?            @map("payload_hash")
  status          SalesInvoiceStatus @default(DRAFT)
  issuedAt        DateTime           @default(now()) @map("issued_at")
  branchId        String?            @map("branch_id")
  customerId      String?            @map("customer_id")
  currency        String             @default("JOD")
  subtotal        Float              @default(0)
  discountTotal   Float              @default(0) @map("discount_total")
  taxTotal        Float              @default(0) @map("tax_total")
  grandTotal      Float              @default(0) @map("grand_total")
  createdByUserId String?            @map("created_by_user_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch?            @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer        Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdBy       User?              @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines           SalesInvoiceLine[]
  payments        SalesPayment[]
  arInvoice       ArInvoice?
  cogsPostingLink CogsPostingLink?

  @@unique([tenantId, invoiceNo])
  @@index([tenantId, issuedAt])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, customerId])
  @@index([tenantId, branchId])
  @@unique([tenantId, idempotencyKey])
  @@map("sales_invoices")
}

model SalesInvoiceLine {
  id             String       @id @default(uuid())
  invoiceId      String       @map("invoice_id")
  tenantId       String       @map("tenant_id")
  productId      String?      @map("product_id")
  itemName       String       @map("item_name")
  qty            Float
  unitPrice      Float        @map("unit_price")
  discount       Float        @default(0)
  taxRate        Float?       @map("tax_rate")
  lineTotal      Float        @default(0) @map("line_total")
  unitCostSnapshot Float?     @map("unit_cost_snapshot")
  costMethodSnapshot String?  @map("cost_method_snapshot")
  createdAt      DateTime     @default(now()) @map("created_at")
  salesInvoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product        Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  inventoryMovements InventoryMovement[]

  @@index([tenantId, invoiceId])
  @@index([tenantId, productId])
  @@map("sales_invoice_lines")
}

model SalesPayment {
  id          String             @id @default(uuid())
  invoiceId   String             @map("invoice_id")
  tenantId    String             @map("tenant_id")
  method      SalesPaymentMethod
  amount      Float
  paidAt      DateTime           @default(now()) @map("paid_at")
  createdByUserId String?        @map("created_by_user_id")
  createdAt   DateTime           @default(now()) @map("created_at")
  salesInvoice SalesInvoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy   User?              @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, invoiceId, paidAt])
  @@map("sales_payments")
}

model CogsPostingLink {
  id             String       @id @default(uuid())
  tenantId       String       @map("tenant_id")
  salesInvoiceId String       @unique @map("sales_invoice_id")
  journalEntryId String       @map("journal_entry_id")
  postedAt       DateTime     @default(now()) @map("posted_at")
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesInvoice   SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)

  @@unique([tenantId, salesInvoiceId])
  @@index([tenantId, postedAt])
  @@map("cogs_posting_links")
}

model Account {
  id            String        @id @default(uuid())
  tenantId      String        @map("tenant_id")
  code          String
  nameAr        String        @map("name_ar")
  nameEn        String        @map("name_en")
  type          AccountType
  normalBalance NormalBalance @map("normal_balance")
  isControl     Boolean       @default(false) @map("is_control")
  isActive      Boolean       @default(true) @map("is_active")
  parentId      String?       @map("parent_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent        Account?      @relation("AccountTree", fields: [parentId], references: [id], onDelete: SetNull)
  children      Account[]     @relation("AccountTree")
  journalLines  JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId, parentId])
  @@map("accounts")
}

model FiscalPeriod {
  id        String           @id @default(uuid())
  tenantId  String           @map("tenant_id")
  year      Int
  month     Int
  status    FiscalPeriodStatus @default(OPEN)
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]
  periodCloses PeriodClose[]
  trialBalanceSnapshots TrialBalanceSnapshot[]
  statementSnapshots StatementSnapshot[]
  reconciliationRuns ReconciliationRun[]

  @@unique([tenantId, year, month])
  @@index([tenantId, status])
  @@map("fiscal_periods")
}

model PeriodClose {
  id             String            @id @default(uuid())
  tenantId       String            @map("tenant_id")
  fiscalPeriodId String            @map("fiscal_period_id")
  status         PeriodCloseStatus
  closedAt       DateTime          @default(now()) @map("closed_at")
  closedByUserId String?           @map("closed_by_user_id")
  notes          String?
  createdAt      DateTime          @default(now()) @map("created_at")
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fiscalPeriod   FiscalPeriod      @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)
  closedByUser   User?             @relation("PeriodCloseByUser", fields: [closedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, fiscalPeriodId, createdAt])
  @@index([tenantId, status, createdAt])
  @@map("period_closes")
}

model TrialBalanceSnapshot {
  id             String      @id @default(uuid())
  tenantId       String      @map("tenant_id")
  fiscalPeriodId String      @map("fiscal_period_id")
  asOfDate       DateTime    @map("as_of_date")
  payload        Json
  createdAt      DateTime    @default(now()) @map("created_at")
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fiscalPeriod   FiscalPeriod @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)

  @@index([tenantId, fiscalPeriodId, createdAt])
  @@map("trial_balance_snapshots")
}

model StatementSnapshot {
  id             String        @id @default(uuid())
  tenantId       String        @map("tenant_id")
  fiscalPeriodId String        @map("fiscal_period_id")
  type           StatementType
  payload        Json
  createdAt      DateTime      @default(now()) @map("created_at")
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fiscalPeriod   FiscalPeriod  @relation(fields: [fiscalPeriodId], references: [id], onDelete: Cascade)

  @@index([tenantId, fiscalPeriodId, type, createdAt])
  @@map("statement_snapshots")
}

model AccountingSetting {
  id                         String   @id @default(uuid())
  tenantId                   String   @unique @map("tenant_id")
  arControlAccountCode       String   @map("ar_control_account_code")
  apControlAccountCode       String   @map("ap_control_account_code")
  inventoryControlAccountCode String  @map("inventory_control_account_code")
  createdAt                  DateTime @default(now()) @map("created_at")
