generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String      @id @default(uuid()) @db.Uuid
  name             String
  subscriptionPlan String      @map("subscription_plan")
  createdAt        DateTime    @default(now()) @map("created_at")
  branches         Branch[]
  users            User[]
  roles            Role[]
  auditLogs        AuditLog[]
  therapeuticClasses TherapeuticClass[]
  dosageForms        DosageForm[]
  storageConditions  StorageCondition[]
  regulatoryTypes    RegulatoryType[]
  products           Product[]
  inventoryMovements InventoryMovement[]

  @@map("tenants")
}

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  location  String
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users     User[]
  inventoryMovements InventoryMovement[]

  @@map("branches")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  branchId     String?  @map("branch_id") @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  auditLogs    AuditLog[]
  inventoryMovements InventoryMovement[]

  @@map("users")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  name            String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  key             String           @unique
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  action    String
  entity    String
  entityId  String    @map("entity_id")
  before    Json?     @db.JsonB
  after     Json?     @db.JsonB
  createdAt DateTime  @default(now()) @map("created_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

enum TrackingMode {
  NONE
  EXPIRY_ONLY
  LOT_EXPIRY
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
}

model TherapeuticClass {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("therapeutic_classes")
}

model DosageForm {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("dosage_forms")
}

model StorageCondition {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("storage_conditions")
}

model RegulatoryType {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("regulatory_types")
}

model Product {
  id                 String                @id @default(uuid()) @db.Uuid
  tenantId           String                @map("tenant_id") @db.Uuid
  therapeuticClassId String?               @map("therapeutic_class_id") @db.Uuid
  dosageFormId       String?               @map("dosage_form_id") @db.Uuid
  storageConditionId String?               @map("storage_condition_id") @db.Uuid
  regulatoryTypeId   String?               @map("regulatory_type_id") @db.Uuid
  nameAr             String                @map("name_ar")
  nameEn             String                @map("name_en")
  barcode            String
  strength           String
  packSize           String                @map("pack_size")
  trackingMode       TrackingMode          @default(NONE) @map("tracking_mode")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  therapeuticClass   TherapeuticClass?     @relation(fields: [therapeuticClassId], references: [id], onDelete: SetNull)
  dosageForm         DosageForm?           @relation(fields: [dosageFormId], references: [id], onDelete: SetNull)
  storageCondition   StorageCondition?     @relation(fields: [storageConditionId], references: [id], onDelete: SetNull)
  regulatoryType     RegulatoryType?       @relation(fields: [regulatoryTypeId], references: [id], onDelete: SetNull)
  inventoryMovements InventoryMovement[]

  @@unique([tenantId, barcode])
  @@index([tenantId, nameEn])
  @@index([tenantId, nameAr])
  @@map("products")
}

model InventoryMovement {
  id           String                @id @default(uuid()) @db.Uuid
  tenantId     String                @map("tenant_id") @db.Uuid
  branchId     String                @map("branch_id") @db.Uuid
  productId    String                @map("product_id") @db.Uuid
  batchNo      String?               @map("batch_no")
  expiryDate   DateTime?             @map("expiry_date")
  movementType InventoryMovementType @map("movement_type")
  quantity     Int
  reason       String?
  createdAt    DateTime              @default(now()) @map("created_at")
  createdBy    String?               @map("created_by") @db.Uuid
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch                @relation(fields: [branchId], references: [id], onDelete: Restrict)
  product      Product               @relation(fields: [productId], references: [id], onDelete: Restrict)
  user         User?                 @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([tenantId, branchId, productId, batchNo])
  @@map("inventory_movements")
}
