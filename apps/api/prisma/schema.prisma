generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("ORION_DATABASE_URL")
}

model Tenant {
  id               String      @id @default(uuid())
  name             String
  subscriptionPlan String      @map("subscription_plan")
  createdAt        DateTime    @default(now()) @map("created_at")
  branches         Branch[]
  users            User[]
  roles            Role[]
  auditLogs        AuditLog[]
  therapeuticClasses TherapeuticClass[]
  dosageForms        DosageForm[]
  storageConditions  StorageCondition[]
  regulatoryTypes    RegulatoryType[]
  products           Product[]
  inventoryMovements InventoryMovement[]
  inventoryBalances  InventoryBalance[]
  suppliers          Supplier[]
  purchaseOrders     PurchaseOrder[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceipts      GoodsReceipt[]
  goodsReceiptLines  GoodsReceiptLine[]
  purchaseReturns    PurchaseReturn[]
  purchaseReturnLines PurchaseReturnLine[]
  procurementAdjustments ProcurementAdjustment[]
  procurementAdjustmentLines ProcurementAdjustmentLine[]
  documentSequences  DocumentSequence[]

  @@map("tenants")
}

model Supplier {
  id                   String   @id @default(uuid())
  tenantId             String   @map("tenant_id")
  code                 String
  nameAr               String   @map("name_ar")
  nameEn               String   @map("name_en")
  contactName          String?  @map("contact_name")
  email                String?
  phone                String?
  address              String?
  preferredPaymentTerm String?  @map("preferred_payment_term")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders       PurchaseOrder[]
  goodsReceipts        GoodsReceipt[]
  purchaseReturns      PurchaseReturn[]

  @@unique([tenantId, code])
  @@index([tenantId, nameEn])
  @@index([tenantId, nameAr])
  @@map("suppliers")
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  name      String
  location  String
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users     User[]
  inventoryMovements InventoryMovement[]
  inventoryBalances  InventoryBalance[]
  purchaseOrders     PurchaseOrder[]
  goodsReceipts      GoodsReceipt[]
  purchaseReturns    PurchaseReturn[]
  procurementAdjustments ProcurementAdjustment[]

  @@map("branches")
}

model User {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  branchId     String?  @map("branch_id")
  roleId       String   @map("role_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  auditLogs    AuditLog[]
  inventoryMovements InventoryMovement[]
  goodsReceiptsCreated GoodsReceipt[]
  purchaseReturnsCreated PurchaseReturn[]
  procurementAdjustmentsCreated ProcurementAdjustment[]

  @@map("users")
}

model Role {
  id              String           @id @default(uuid())
  tenantId        String           @map("tenant_id")
  name            String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users           User[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id        String    @id @default(uuid())
  tenantId  String    @map("tenant_id")
  userId    String?   @map("user_id")
  action    String
  entity    String
  entityId  String    @map("entity_id")
  before    Json?
  after     Json?
  createdAt DateTime  @default(now()) @map("created_at")
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

enum TrackingMode {
  NONE
  EXPIRY_ONLY
  LOT_EXPIRY
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  CLOSED
  CANCELLED
}

model TherapeuticClass {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("therapeutic_classes")
}

model DosageForm {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("dosage_forms")
}

model StorageCondition {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("storage_conditions")
}

model RegulatoryType {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  nameAr    String   @map("name_ar")
  nameEn    String   @map("name_en")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([tenantId, nameEn])
  @@map("regulatory_types")
}

model Product {
  id                 String                @id @default(uuid())
  tenantId           String                @map("tenant_id")
  therapeuticClassId String?               @map("therapeutic_class_id")
  dosageFormId       String?               @map("dosage_form_id")
  storageConditionId String?               @map("storage_condition_id")
  regulatoryTypeId   String?               @map("regulatory_type_id")
  nameAr             String                @map("name_ar")
  nameEn             String                @map("name_en")
  barcode            String
  strength           String
  packSize           String                @map("pack_size")
  trackingMode       TrackingMode          @default(NONE) @map("tracking_mode")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  therapeuticClass   TherapeuticClass?     @relation(fields: [therapeuticClassId], references: [id], onDelete: SetNull)
  dosageForm         DosageForm?           @relation(fields: [dosageFormId], references: [id], onDelete: SetNull)
  storageCondition   StorageCondition?     @relation(fields: [storageConditionId], references: [id], onDelete: SetNull)
  regulatoryType     RegulatoryType?       @relation(fields: [regulatoryTypeId], references: [id], onDelete: SetNull)
  inventoryMovements InventoryMovement[]
  inventoryBalances  InventoryBalance[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceiptLines  GoodsReceiptLine[]
  purchaseReturnLines PurchaseReturnLine[]
  procurementAdjustmentLines ProcurementAdjustmentLine[]

  @@unique([tenantId, barcode])
  @@index([tenantId, nameEn])
  @@index([tenantId, nameAr])
  @@map("products")
}

model InventoryMovement {
  id           String                @id @default(uuid())
  tenantId     String                @map("tenant_id")
  branchId     String                @map("branch_id")
  productId    String                @map("product_id")
  batchNo      String?               @map("batch_no")
  expiryDate   DateTime?             @map("expiry_date")
  movementType InventoryMovementType @map("movement_type")
  quantity     Int
  reason       String?
  createdAt    DateTime              @default(now()) @map("created_at")
  createdBy    String?               @map("created_by")
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch                @relation(fields: [branchId], references: [id], onDelete: Restrict)
  product      Product               @relation(fields: [productId], references: [id], onDelete: Restrict)
  user         User?                 @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  goodsReceiptLine GoodsReceiptLine?
  purchaseReturnLine PurchaseReturnLine?
  procurementAdjustmentLine ProcurementAdjustmentLine?

  @@index([tenantId, branchId, productId, batchNo])
  @@map("inventory_movements")
}

model InventoryBalance {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  branchId  String   @map("branch_id")
  productId String   @map("product_id")
  batchNo   String   @default("") @map("batch_no")
  quantity  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([tenantId, branchId, productId, batchNo])
  @@index([tenantId, branchId, productId])
  @@map("inventory_balances")
}

model DocumentSequence {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  key        String
  nextNumber Int      @default(1) @map("next_number")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@map("document_sequences")
}

model PurchaseOrder {
  id         String              @id @default(uuid())
  tenantId   String              @map("tenant_id")
  branchId   String              @map("branch_id")
  supplierId String              @map("supplier_id")
  poNumber   String              @map("po_number")
  status     PurchaseOrderStatus @default(DRAFT)
  notes      String?
  orderedAt  DateTime            @default(now()) @map("ordered_at")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch     Branch              @relation(fields: [branchId], references: [id], onDelete: Restrict)
  supplier   Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  lines      PurchaseOrderLine[]
  goodsReceipts GoodsReceipt[]

  @@unique([tenantId, poNumber])
  @@index([tenantId, status, orderedAt])
  @@index([tenantId, supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id              String        @id @default(uuid())
  purchaseOrderId String        @map("purchase_order_id")
  tenantId        String        @map("tenant_id")
  productId       String        @map("product_id")
  quantity        Int
  receivedQuantity Int           @default(0) @map("received_quantity")
  unitPrice       Float         @map("unit_price")
  lineTotal       Float         @map("line_total")
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  goodsReceiptLines GoodsReceiptLine[]

  @@index([tenantId, purchaseOrderId])
  @@index([tenantId, productId])
  @@map("purchase_order_lines")
}

model GoodsReceipt {
  id             String             @id @default(uuid())
  tenantId       String             @map("tenant_id")
  branchId       String             @map("branch_id")
  supplierId     String             @map("supplier_id")
  purchaseOrderId String            @map("purchase_order_id")
  grnNumber      String             @map("grn_number")
  idempotencyKey String             @map("idempotency_key")
  payloadHash    String             @map("payload_hash")
  notes          String?
  receivedAt     DateTime           @default(now()) @map("received_at")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  createdBy      String?            @map("created_by")
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch             @relation(fields: [branchId], references: [id], onDelete: Restrict)
  supplier       Supplier           @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseOrder  PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  creator        User?              @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  lines          GoodsReceiptLine[]
  purchaseReturns PurchaseReturn[]

  @@unique([tenantId, grnNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, receivedAt])
  @@index([tenantId, purchaseOrderId])
  @@map("goods_receipts")
}

model GoodsReceiptLine {
  id                String            @id @default(uuid())
  goodsReceiptId    String            @map("goods_receipt_id")
  purchaseOrderLineId String          @map("purchase_order_line_id")
  tenantId          String            @map("tenant_id")
  productId         String            @map("product_id")
  inventoryMovementId String?         @unique @map("inventory_movement_id")
  qtyReceivedNow    Int               @map("qty_received_now")
  returnedQuantity  Int               @default(0) @map("returned_quantity")
  batchNo           String?           @map("batch_no")
  expiryDate        DateTime?         @map("expiry_date")
  notes             String?
  createdAt         DateTime          @default(now()) @map("created_at")
  goodsReceipt      GoodsReceipt      @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  purchaseOrderLine PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id], onDelete: Restrict)
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product           Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  inventoryMovement InventoryMovement? @relation(fields: [inventoryMovementId], references: [id], onDelete: SetNull)
  purchaseReturnLines PurchaseReturnLine[]

  @@index([tenantId, goodsReceiptId])
  @@index([tenantId, purchaseOrderLineId])
  @@index([tenantId, productId])
  @@map("goods_receipt_lines")
}

model PurchaseReturn {
  id               String               @id @default(uuid())
  tenantId         String               @map("tenant_id")
  goodsReceiptId   String               @map("goods_receipt_id")
  returnNumber     String               @map("return_number")
  idempotencyKey   String               @map("idempotency_key")
  payloadHash      String               @map("payload_hash")
  branchId         String               @map("branch_id")
  supplierId       String               @map("supplier_id")
  reasonCode       String?              @map("reason_code")
  notes            String?
  returnedAt       DateTime             @default(now()) @map("returned_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  createdBy        String?              @map("created_by")
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch           Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  supplier         Supplier             @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  goodsReceipt     GoodsReceipt         @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  creator          User?                @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  lines            PurchaseReturnLine[]

  @@unique([tenantId, returnNumber])
  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, returnedAt])
  @@index([tenantId, goodsReceiptId])
  @@index([tenantId, supplierId])
  @@map("purchase_returns")
}

model PurchaseReturnLine {
  id                  String             @id @default(uuid())
  purchaseReturnId    String             @map("purchase_return_id")
  goodsReceiptLineId  String             @map("goods_receipt_line_id")
  tenantId            String             @map("tenant_id")
  productId           String             @map("product_id")
  inventoryMovementId String?            @unique @map("inventory_movement_id")
  qtyReturnedNow      Int                @map("qty_returned_now")
  reasonCode          String?            @map("reason_code")
  batchNo             String?            @map("batch_no")
  expiryDate          DateTime?          @map("expiry_date")
  notes               String?
  createdAt           DateTime           @default(now()) @map("created_at")
  purchaseReturn      PurchaseReturn     @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  goodsReceiptLine    GoodsReceiptLine   @relation(fields: [goodsReceiptLineId], references: [id], onDelete: Restrict)
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product             Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  inventoryMovement   InventoryMovement? @relation(fields: [inventoryMovementId], references: [id], onDelete: SetNull)

  @@index([tenantId, purchaseReturnId])
  @@index([tenantId, goodsReceiptLineId])
  @@index([tenantId, productId])
  @@map("purchase_return_lines")
}

model ProcurementAdjustment {
  id                 String                      @id @default(uuid())
  tenantId           String                      @map("tenant_id")
  branchId           String                      @map("branch_id")
  adjustmentNumber   String                      @map("adjustment_number")
  reasonCode         String                      @map("reason_code")
  sourceRefType      String?                     @map("source_ref_type")
  sourceRefId        String?                     @map("source_ref_id")
  notes              String?
  adjustedAt         DateTime                    @default(now()) @map("adjusted_at")
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")
  createdBy          String?                     @map("created_by")
  tenant             Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch             Branch                      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  creator            User?                       @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  lines              ProcurementAdjustmentLine[]

  @@unique([tenantId, adjustmentNumber])
  @@index([tenantId, adjustedAt])
  @@map("procurement_adjustments")
}

model ProcurementAdjustmentLine {
  id                      String                 @id @default(uuid())
  procurementAdjustmentId String                 @map("procurement_adjustment_id")
  tenantId                String                 @map("tenant_id")
  productId               String                 @map("product_id")
  inventoryMovementId     String?                @unique @map("inventory_movement_id")
  quantityDelta           Int                    @map("quantity_delta")
  reasonCode              String?                @map("reason_code")
  batchNo                 String?                @map("batch_no")
  expiryDate              DateTime?              @map("expiry_date")
  notes                   String?
  createdAt               DateTime               @default(now()) @map("created_at")
  procurementAdjustment   ProcurementAdjustment  @relation(fields: [procurementAdjustmentId], references: [id], onDelete: Cascade)
  tenant                  Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product                 Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  inventoryMovement       InventoryMovement?     @relation(fields: [inventoryMovementId], references: [id], onDelete: SetNull)

  @@index([tenantId, procurementAdjustmentId])
  @@index([tenantId, productId])
  @@map("procurement_adjustment_lines")
}
