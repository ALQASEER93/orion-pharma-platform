# ORION PHARMA environment (Docker-less defaults)
ORION_DB_PROVIDER=sqlite
ORION_DATABASE_URL=

# Optional PostgreSQL override (used when ORION_DB_PROVIDER=postgresql)
ORION_DB_HOST=localhost
ORION_DB_PORT=5432
ORION_DB_NAME=orion_pharma
ORION_DB_USER=postgres
ORION_DB_PASSWORD=postgres

ORION_JWT_SECRET=ORION_local_dev_jwt_secret_change_in_production
ORION_JWT_EXPIRES_IN_SECONDS=86400
ORION_PORT=3001
ORION_WEB_API_BASE_URL=http://localhost:3001
